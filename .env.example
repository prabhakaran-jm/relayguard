# RelayGuard environment configuration

# Database target: local (Docker) or cloud (CockroachDB Cloud)
RELAYGUARD_DB_TARGET=local

# Local Docker CockroachDB (default demo)
DATABASE_URL_LOCAL=postgresql://root@localhost:26257/relayguard?sslmode=disable

# CockroachDB Cloud connection string (set when RELAYGUARD_DB_TARGET=cloud)
# Example: postgresql://relayguard:<password>@<cluster-host>:26257/relayguard?sslmode=verify-full
DATABASE_URL_CLOUD=

# Legacy single URL (still supported; cloud target falls back to this if DATABASE_URL_CLOUD is unset)
DATABASE_URL=postgresql://root@localhost:26257/relayguard?sslmode=disable

# Embedding storage: auto (prefer VECTOR), vector (force VECTOR), float_array (local OSS fallback)
COCKROACH_VECTOR_MODE=auto

# ccloud CLI metadata (no secrets)
CCLOUD_CLUSTER_NAME=
CCLOUD_DATABASE_NAME=relayguard

LEASE_TTL_SECONDS=5
FAIL_AFTER=
WORKER_ID=worker-a
ACTION_SELECTOR=mock
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
AWS_REGION=us-east-1
INCIDENT_SEVERITY=high
ACTION_MIN_CONFIDENCE=0.5

# AWS Lambda (M6) — Secrets Manager database URL for deployed workers
RELAYGUARD_DATABASE_SECRET_NAME=
RELAYGUARD_LAMBDA_FUNCTION_NAME=relayguard-worker
